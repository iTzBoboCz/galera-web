{
  "name": "galera-web",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "serve": "vite preview",
    "lint:js": "biome check .",
    "lint:style": "stylelint **/*.{vue,css} --ignore-path .gitignore .",
    "lint": "npm run lint:js && npm run lint:style",
    "biome:fix": "biome check --write .",
    "biome:format": "biome format --write ."
  },
  "dependencies": {
    "@galera/client-axios": "github:galera-org/galera-client-axios",
    "@mdi/font": "7",
    "axios": "1",
    "iso-639-1": "3.1",
    "pinia": "3.0",
    "pinia-plugin-persistedstate": "4.7",
    "vite-plugin-pages": "0.33",
    "vite-plugin-vue-layouts": "0.11",
    "vue": "3.5",
    "vue-i18n": "9.2.2",
    "vue-router": "4",
    "vuetify": "3.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@intlify/unplugin-vue-i18n": "11.2.4",
    "@types/node": "24",
    "@vitejs/plugin-vue": "6",
    "postcss-html": "1.8.0",
    "sass": "1",
    "stylelint": "17",
    "stylelint-config-recommended-vue": "1.6",
    "stylelint-config-standard": "40",
    "typescript": "6",
    "vite": "8",
    "vue-tsc": "3"
  }
}
