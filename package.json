{
  "name": "galera-web",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "serve": "vite preview",
    "lint:js": "ESLINT_USE_FLAT_CONFIG=false eslint --ext .ts,.js,.json,.vue --ignore-path .gitignore .",
    "lint:style": "stylelint **/*.{vue,css} --ignore-path .gitignore .",
    "lint": "npm run lint:js && npm run lint:style",
    "biome:check": "biome check .",
    "biome:lint": "biome check --write .",
    "biome:format": "biome format --write ."
  },
  "dependencies": {
    "@galera/client-axios": "github:galera-org/galera-client-axios",
    "@mdi/font": "7",
    "axios": "1",
    "iso-639-1": "3.1",
    "pinia": "3.0",
    "pinia-plugin-persistedstate": "4.7",
    "vite-plugin-pages": "0.33",
    "vite-plugin-vue-layouts": "0.11",
    "vue": "3.5",
    "vue-i18n": "9.2.2",
    "vue-router": "4",
    "vuetify": "3.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@intlify/unplugin-vue-i18n": "0.11.0",
    "@types/node": "24",
    "@typescript-eslint/eslint-plugin": "8.61",
    "@typescript-eslint/parser": "8.61",
    "@vitejs/plugin-vue": "6",
    "eslint": "9",
    "eslint-config-prettier": "9",
    "eslint-import-resolver-typescript": "4.4",
    "eslint-plugin-import": "2.32",
    "eslint-plugin-prettier": "5.5",
    "eslint-plugin-promise": "7.3",
    "eslint-plugin-simple-import-sort": "13",
    "eslint-plugin-unicorn": "56",
    "eslint-plugin-vue": "9.25",
    "postcss-html": "1.8.0",
    "prettier": "3.8",
    "sass": "1",
    "stylelint": "17",
    "stylelint-config-recommended-vue": "1.6",
    "stylelint-config-standard": "40",
    "typescript": "6",
    "vite": "5",
    "vue-tsc": "3"
  }
}
